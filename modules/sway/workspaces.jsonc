{
	"sway/workspaces": {
		// "active-only":
		// "all-outputs":
		"format": "{icon}",
		"format-icons": {
			"focused": "",
			"default": ""
		},
		"persistent-workspaces": {
			"*": 5
		},
		// "persistent-only":
		// "numeric-first":
		// "sort-by":
		"on-scroll-up": "swaymsg workspace next_on_output",
		"on-scroll-down": "swaymsg workspace prev_on_output",
		// "expand":
		"cursor": true
	}
}
